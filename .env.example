# Discord Bot Configuration
BOT_TOKEN=your_discord_bot_token_here

# API Server Configuration
PORT=3001
CORS_ORIGIN=http://example.com

# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback
JWT_SECRET=your_jwt_secret_here

# Database Backend: "sqlite" or "mysql"
DB_BACKEND=mysql

# SQLite Configuration (used when DB_BACKEND=sqlite)
DB_PATH=/app/data/sqbot.sqlite3

# MySQL Configuration (used when DB_BACKEND=mysql)
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sqbot_password
DB_NAME=sqbot

# Path to yt-dlp binary (pre-configured in Docker container)
YTDLP_PATH=/usr/bin/yt-dlp

# Node Environment
NODE_ENV=production
