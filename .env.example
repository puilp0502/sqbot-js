# Discord Bot Configuration
BOT_TOKEN=your_discord_bot_token_here

# API Server Configuration
PORT=3001
ADMIN_USERNAME=admin
ADMIN_PASSWORD=secure_password_here
CORS_ORIGIN=http://example.com

# Database Configuration
DB_PATH=/app/data/sqbot.sqlite3

# Path to yt-dlp binary (pre-configured in Docker container)
YTDLP_PATH=/usr/bin/yt-dlp

# Node Environment
NODE_ENV=production

# Discord OAuth Configuration (optional - for user authentication via Discord)
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_CALLBACK_URL=http://localhost:3001/auth/discord/callback

# Session Configuration
# Generate a secure random string for production: openssl rand -hex 32
SESSION_SECRET=your_session_secret_here

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173